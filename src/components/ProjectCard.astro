---
// ProjectCard.astro
// Replaces your existing project link rows in the Work section.
// Gives each project a visual number, animated reveal on scroll,
// and a magnetic hover state (works with CustomCursor.astro).
//
// USAGE:
//   <ProjectCard number="01.01" title="AEGIS" role="Security Framework · AI Agents" year="2025" href="/case-studies/aegis">
//     Private project. A framework for evaluating how vulnerable AI agents...
//   </ProjectCard>

interface Props {
  number: string;
  title: string;
  role: string;
  year: string;
  href: string;
  status?: string; // e.g. "Live" | "Beta" | "In Development"
}

const { number, title, role, year, href, status } = Astro.props;
---

<a href={href} class="project-card" data-cursor-hover>
  <div class="project-card__number">{number}</div>
  <div class="project-card__body">
    <div class="project-card__top">
      <h3 class="project-card__title">{title}</h3>
      {status && <span class="project-card__status">{status}</span>}
    </div>
    <p class="project-card__desc">
      <slot />
    </p>
    <div class="project-card__meta">
      <span class="project-card__role">{role}</span>
      <span class="project-card__year">{year}</span>
    </div>
  </div>
  <div class="project-card__arrow">→</div>
</a>

<style>
  .project-card {
    display: grid;
    grid-template-columns: 56px 1fr 32px;
    align-items: start;
    gap: 0 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    text-decoration: none;
    color: inherit;
    position: relative;
    cursor: none; /* handled by CustomCursor */

    /* Entrance animation — starts invisible */
    opacity: 0;
    transform: translateY(24px);

    transition:
      border-color 0.3s ease,
      background 0.3s ease;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0 -2rem;
    background: rgba(255, 255, 255, 0);
    transition: background 0.35s ease;
    pointer-events: none;
    border-radius: 4px;
  }

  .project-card:hover::before {
    background: rgba(255, 255, 255, 0.025);
  }

  .project-card:hover .project-card__arrow {
    transform: translate(6px, -4px);
    opacity: 1;
  }

  .project-card:hover .project-card__title {
    color: #fff;
  }

  .project-card__number {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.08em;
    padding-top: 4px;
    font-variant-numeric: tabular-nums;
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-card__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card__title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    transition: color 0.2s ease;
  }

  .project-card__status {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.4);
  }

  .project-card__desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.65;
    margin: 0;
    max-width: 560px;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }

  .project-card__role {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.28);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .project-card__year {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.2);
    font-variant-numeric: tabular-nums;
  }

  .project-card__arrow {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    padding-top: 6px;
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.3s ease;
    opacity: 0.3;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Staggered scroll-reveal for all project cards
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  cards.forEach((card, i) => {
    gsap.to(card, {
      scrollTrigger: {
        trigger: card,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      opacity: 1,
      y: 0,
      duration: 0.65,
      ease: 'power2.out',
      delay: i * 0.07, // stagger between cards
    });
  });
</script>
