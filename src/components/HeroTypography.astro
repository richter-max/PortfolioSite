---
// HeroTypography.astro
// Replace your existing hero headline markup with this component.
// Requires GSAP + ScrollTrigger — add to package.json:
//   npm install gsap
// Then import in this file (done below via CDN for zero-config drop-in).
// 
// USAGE in your hero section:
//   <HeroTypography />
// 
// The component renders:
//   - "Built under" on line 1 → splits into characters, each staggered in
//   - "pressure." on line 2 → scales up on load, then compresses on scroll
//   - Sub-headline fades in after title
//   - On scroll: title chars scatter upward/outward (parallax dispersion)
---

<div id="hero-headline" aria-label="Built under pressure.">
  <div class="hero-line" id="hero-line-1" aria-hidden="true">
    <span class="word">Built</span>
    <span class="word">under</span>
  </div>
  <div class="hero-line hero-line--accent" id="hero-line-2" aria-hidden="true">
    <span class="word">pressure.</span>
  </div>
</div>

<p id="hero-sub" class="hero-sub">
  Systems that perform when they cannot fail.<br />
  Hardened against adversaries. Tested in the cold.
</p>

<style>
  #hero-headline {
    overflow: visible;
    line-height: 0.92;
    margin: 0 0 2rem;
    user-select: none;
  }

  .hero-line {
    display: block;
    /* Inherit font styles from parent — set these on your hero section */
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    white-space: nowrap;
  }

  .hero-line--accent {
    /* Slightly larger for the punch word */
    font-size: clamp(4.5rem, 11vw, 10rem);
    color: #fff;
  }

  /* Individual char wrappers injected by GSAP SplitText */
  .hero-headline-char {
    display: inline-block;
    /* Prevent layout collapse during animation */
    will-change: transform, opacity;
  }

  .hero-sub {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    letter-spacing: 0.01em;
    max-width: 480px;
    margin: 0;
    opacity: 0; /* animated in */
  }

  /* Space between words — SplitText removes natural spaces */
  .word {
    display: inline-block;
    margin-right: 0.28em;
  }
  .word:last-child {
    margin-right: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Manual char split (no SplitText plugin needed) ──────────────────────
  function splitChars(el: Element) {
    const words = el.querySelectorAll('.word');
    words.forEach((word) => {
      const text = word.textContent || '';
      word.textContent = '';
      text.split('').forEach((char) => {
        const span = document.createElement('span');
        span.className = 'hero-headline-char';
        span.textContent = char === ' ' ? '\u00A0' : char;
        word.appendChild(span);
      });
    });
  }

  const headline = document.getElementById('hero-headline');
  const line1 = document.getElementById('hero-line-1');
  const line2 = document.getElementById('hero-line-2');
  const sub = document.getElementById('hero-sub');

  if (headline && line1 && line2 && sub) {
    splitChars(line1);
    splitChars(line2);

    const chars1 = line1.querySelectorAll<HTMLElement>('.hero-headline-char');
    const chars2 = line2.querySelectorAll<HTMLElement>('.hero-headline-char');

    // ─── ENTRANCE ANIMATION ────────────────────────────────────────────────
    // Line 1: chars fall in from top, staggered
    gsap.set(chars1, { y: -60, opacity: 0, rotateX: -40 });
    gsap.to(chars1, {
      y: 0,
      opacity: 1,
      rotateX: 0,
      duration: 0.7,
      ease: 'expo.out',
      stagger: {
        each: 0.03,
        from: 'start',
      },
      delay: 0.1,
    });

    // Line 2: "pressure." scales up from slightly smaller
    gsap.set(chars2, { scale: 0.6, opacity: 0, transformOrigin: 'left center' });
    gsap.to(chars2, {
      scale: 1,
      opacity: 1,
      duration: 0.9,
      ease: 'expo.out',
      stagger: { each: 0.025, from: 'start' },
      delay: 0.35,
    });

    // Sub headline fades in last
    gsap.to(sub, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power2.out',
      delay: 0.85,
    });
    gsap.set(sub, { y: 16 });

    // ─── SCROLL DISPERSION ────────────────────────────────────────────────
    // As user scrolls down, chars scatter outward like an explosion
    const allChars = [...chars1, ...chars2];
    const total = allChars.length;

    allChars.forEach((char, i) => {
      const progress = i / (total - 1); // 0 → 1
      // Each char gets a unique scatter vector
      const xDrift = (Math.random() - 0.5) * 300 * (1 + Math.abs(progress - 0.5));
      const yDrift = -(Math.random() * 200 + 80);
      const rotateDrift = (Math.random() - 0.5) * 120;

      gsap.to(char, {
        scrollTrigger: {
          trigger: headline,
          start: 'top top',
          end: 'bottom top',
          scrub: 1.2,
        },
        x: xDrift,
        y: yDrift,
        opacity: 0,
        rotate: rotateDrift,
        scale: 0.4 + Math.random() * 0.4,
        ease: 'none',
      });
    });

    // Sub headline fades on scroll too
    gsap.to(sub, {
      scrollTrigger: {
        trigger: headline,
        start: 'top top',
        end: '40% top',
        scrub: 1,
      },
      opacity: 0,
      y: -30,
      ease: 'none',
    });
  }
</script>
