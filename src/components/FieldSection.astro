---
// FieldSection.astro
// Ersetzt deine bestehende "02 FIELD" Section komplett.
// Horizontal scroll: User scrollt vertikal, Cards traversieren horizontal —
// wie eine Rennstrecke die man entlangläuft.
//
// USAGE in index.astro:
//   import FieldSection from '../components/FieldSection.astro';
//   <FieldSection />
//
// Requires: npm install gsap (bereits von P1 installiert)

interface Event {
  id: string;
  index: string;
  location: string;
  date: string;
  title: string;
  subtitle: string;
  stats: { label: string; value: string }[];
  tag: string;
}

const events: Event[] = [
  {
    id: 'kraichgau',
    index: '02.01',
    location: 'KRAICHGAU · DE',
    date: 'MAY 2026',
    title: 'Ironman 70.3',
    subtitle: 'Kraichgau',
    stats: [
      { label: 'TARGET', value: '≤ 5:00' },
      { label: 'TOTAL', value: '211 km' },
    ],
    tag: 'Half-Iron',
  },
  {
    id: 'berlin',
    index: '02.02',
    location: 'BERLIN · DE',
    date: 'SEP 2026',
    title: 'Berlin Marathon',
    subtitle: '42.195 km',
    stats: [
      { label: 'TARGET', value: '≤ 3:00:00' },
      { label: 'PACE', value: '4:16/km' },
    ],
    tag: 'Marathon',
  },
  {
    id: 'tt',
    index: '02.03',
    location: 'BAYERN · DE',
    date: '2025/26',
    title: 'Table Tennis',
    subtitle: 'Landesliga',
    stats: [
      { label: 'CURRENT', value: '1,740' },
      { label: 'TARGET', value: '1,800' },
    ],
    tag: 'League',
  },
];
---

<section id="field" class="field-section">
  <!-- Section label — pinned left, fades as you scroll -->
  <div class="field-label">
    <span class="field-label__num">02</span>
    <span class="field-label__title">FIELD</span>
  </div>

  <!-- Intro headline — fades out as horizontal scroll begins -->
  <div class="field-intro" id="field-intro">
    <h2 class="field-intro__headline">Tested in the cold.</h2>
    <p class="field-intro__sub">
      Endurance is not a hobby. It is the same practice —<br />
      systems under load, failure modes, recovery.
    </p>
    <div class="field-intro__hint" id="scroll-hint">
      <span class="hint-line"></span>
      <span class="hint-text">scroll to traverse</span>
    </div>
  </div>

  <!-- Horizontal track — this is what moves -->
  <div class="field-track-wrapper" id="field-track-wrapper">
    <div class="field-track" id="field-track">
      {
        events.map((event, i) => (
          <div class="field-card" data-index={i}>
            <div class="field-card__header">
              <span class="field-card__index">{event.index}</span>
              <span class="field-card__tag">{event.tag}</span>
            </div>
            <div class="field-card__location">
              {event.location} · {event.date}
            </div>
            <div class="field-card__title-group">
              <h3 class="field-card__title">{event.title}</h3>
              <p class="field-card__subtitle">{event.subtitle}</p>
            </div>
            <div class="field-card__divider" />
            <div class="field-card__stats">
              {event.stats.map((stat) => (
                <div class="field-card__stat">
                  <span class="field-card__stat-value">{stat.value}</span>
                  <span class="field-card__stat-label">{stat.label}</span>
                </div>
              ))}
            </div>
            <!-- Progress bar — animates on card enter -->
            <div class="field-card__progress">
              <div class="field-card__progress-bar" data-id={event.id} />
            </div>
          </div>
        ))
      }

      <!-- End card — "same discipline" closer -->
      <div class="field-card field-card--closer">
        <p class="closer-text">Two arenas.<br />Same discipline.</p>
        <p class="closer-sub">Reps, film, quiet volume.</p>
      </div>
    </div>
  </div>

  <!-- Progress dots -->
  <div class="field-dots" id="field-dots">
    {events.map((_, i) => <button class={`field-dot ${i === 0 ? 'is-active' : ''}`} data-dot={i} aria-label={`Event ${i + 1}`} />)}
  </div>
</section>

<style>
  .field-section {
    position: relative;
    /* Height defines total scroll distance for the horizontal pan.
       More height = slower traversal. Adjust to taste. */
    height: 350vh;
    overflow: hidden; /* the track overflows horizontally */
  }

  /* Section label — top left, always visible */
  .field-label {
    position: sticky;
    top: 2rem;
    left: 2.5rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    z-index: 10;
    pointer-events: none;
    margin-left: 2.5rem;
  }

  .field-label__num {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
  }

  .field-label__title {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.12em;
  }

  /* Intro block */
  .field-intro {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 max(2.5rem, 8vw);
    pointer-events: none;
    z-index: 5;
  }

  .field-intro__headline {
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 0.95;
    margin: 0 0 1.5rem;
  }

  .field-intro__sub {
    font-size: clamp(0.9rem, 1.4vw, 1rem);
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.7;
    margin: 0 0 3rem;
  }

  .field-intro__hint {
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0; /* animated in via JS */
  }

  .hint-line {
    display: block;
    width: 40px;
    height: 1px;
    background: rgba(255, 255, 255, 0.25);
  }

  .hint-text {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Track wrapper — sticky container for the horizontal scroll */
  .field-track-wrapper {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    margin-top: -100vh; /* overlap with intro */
    z-index: 6;
    pointer-events: none; /* JS re-enables on cards */
  }

  .field-track {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2rem;
    padding: 0 max(2.5rem, 8vw);
    /* Width: enough for all cards + padding */
    will-change: transform;
    pointer-events: auto;
  }

  /* Event cards */
  .field-card {
    flex-shrink: 0;
    width: min(480px, 85vw);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: 1.2rem;

    /* Card entrance animation */
    opacity: 0;
    transform: translateX(40px);
    transition:
      border-color 0.3s ease,
      background 0.3s ease;
  }

  .field-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .field-card--closer {
    width: min(360px, 75vw);
    border: none;
    background: none;
    justify-content: center;
  }

  .field-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .field-card__index {
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
  }

  .field-card__tag {
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.35);
  }

  .field-card__location {
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .field-card__title-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .field-card__title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
    line-height: 1;
  }

  .field-card__subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .field-card__divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
  }

  .field-card__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .field-card__stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .field-card__stat-value {
    font-size: 1.4rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .field-card__stat-label {
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Progress bar */
  .field-card__progress {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 1px;
    overflow: hidden;
  }

  .field-card__progress-bar {
    height: 100%;
    width: 0%;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 1px;
    transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Progress bar fill values per card */
  .field-card__progress-bar[data-id='kraichgau'] { --fill: 62%; }
  .field-card__progress-bar[data-id='berlin']    { --fill: 45%; }
  .field-card__progress-bar[data-id='tt']        { --fill: 78%; }

  .field-card__progress-bar.is-visible {
    width: var(--fill, 50%);
  }

  /* Closer card */
  .closer-text {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.05;
    margin: 0;
  }

  .closer-sub {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.25);
    margin: 1rem 0 0;
    letter-spacing: 0.02em;
  }

  /* Progress dots */
  .field-dots {
    position: fixed;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 20;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .field-dots.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .field-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    cursor: none;
    padding: 0;
    transition:
      background 0.3s ease,
      transform 0.3s ease;
  }

  .field-dot.is-active {
    background: rgba(255, 255, 255, 0.8);
    transform: scale(1.3);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.getElementById('field') as HTMLElement;
  const track = document.getElementById('field-track') as HTMLElement;
  const intro = document.getElementById('field-intro') as HTMLElement;
  const dots = document.getElementById('field-dots') as HTMLElement;
  const hint = document.getElementById('scroll-hint') as HTMLElement;
  const cards = document.querySelectorAll<HTMLElement>('.field-card:not(.field-card--closer)');

  if (section && track) {
    // Total horizontal distance to travel
    const trackWidth = track.scrollWidth;
    const viewportWidth = window.innerWidth;
    const travelDistance = trackWidth - viewportWidth;

    // ── Hint fade in ──────────────────────────────────────────────────────
    gsap.to(hint, { opacity: 1, duration: 0.8, delay: 0.5 });

    // ── Intro fade out as horizontal scroll begins ────────────────────────
    gsap.to(intro, {
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '15% top',
        scrub: 1,
      },
      opacity: 0,
      y: -40,
      ease: 'none',
    });

    // ── Main horizontal pan ───────────────────────────────────────────────
    const panTl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        pin: false, // track-wrapper is sticky — no pin needed
        onUpdate: (self) => {
          // Show/hide dots
          if (self.progress > 0.05 && self.progress < 0.95) {
            dots.classList.add('is-visible');
          } else {
            dots.classList.remove('is-visible');
          }

          // Update active dot
          const dotIndex = Math.min(
            Math.floor(self.progress * cards.length),
            cards.length - 1
          );
          document.querySelectorAll('.field-dot').forEach((dot, i) => {
            dot.classList.toggle('is-active', i === dotIndex);
          });
        },
      },
    });

    panTl.to(track, {
      x: -travelDistance,
      ease: 'none',
    });

    // ── Card entrance animations (staggered as they come into view) ───────
    cards.forEach((card, i) => {
      const progressStart = (i / (cards.length + 1)) * 0.9;
      const progressEnd = progressStart + 0.15;

      gsap.to(card, {
        scrollTrigger: {
          trigger: section,
          start: `${progressStart * 100}% top`,
          end: `${progressEnd * 100}% top`,
          scrub: false,
          toggleActions: 'play none none none',
          onEnter: () => {
            // Animate progress bar on card enter
            const bar = card.querySelector<HTMLElement>('.field-card__progress-bar');
            if (bar) bar.classList.add('is-visible');
          },
        },
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
      });
    });

    // ── Dot click → scroll to card position ───────────────────────────────
    document.querySelectorAll('.field-dot').forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const targetProgress = (i / cards.length) * 0.85 + 0.05;
        const sectionTop = section.offsetTop;
        const sectionHeight = section.offsetHeight;
        window.scrollTo({
          top: sectionTop + sectionHeight * targetProgress,
          behavior: 'smooth',
        });
      });
    });
  }
</script>
