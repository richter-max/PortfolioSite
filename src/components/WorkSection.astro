---
// WorkSection.astro
// Header pinnt zuerst an der Decke — Karten stacken sich darunter auf.

const projects = [
  {
    index: '01.01',
    client: 'AEGIS',
    role: 'Security Framework · AI Agents',
    year: '2025',
    summary: 'Private project. A framework for evaluating how vulnerable AI agents are to prompt injection, data exfiltration, and unauthorized actions. Built from scratch. Tested across agent architectures; surfaced vulnerability classes before deployment.',
    href: '/case-studies/aegis',
    image: '/img/blog-career.jpg',
    tag: 'Security Research',
  },
  {
    index: '01.02',
    client: 'Attack Surface Scanner',
    role: 'CLI Tool · Open Source',
    year: '2025',
    summary: 'Automated reconnaissance — DNS, open ports, subdomains, security headers — in one command. Full scan under thirty seconds. Live demo on the site.',
    href: '#',
    image: '/img/blog-extreme.jpg',
    tag: 'Open Source',
  },
  {
    index: '01.03',
    client: 'VendorQ',
    role: 'B2B SaaS · Beta',
    year: '2025',
    summary: 'AI reads existing security docs and auto-generates answers for vendor questionnaires. Two-week process compressed to a two-hour review. ~70% faster turnaround.',
    href: '#',
    image: '/img/blog-shenzhen.jpg',
    tag: 'SaaS · Beta',
  },
  {
    index: '01.04',
    client: 'SMB Security Tool',
    role: 'Security Product · In Development',
    year: '2026',
    summary: 'Enterprise-grade security for companies with 10–200 employees. One-click setup, automated scanning, reports a non-technical CEO can understand.',
    href: '#',
    image: '/img/blog-endurance.jpg',
    tag: 'In Development',
  },
];

// Pixel-Höhe des Headers — Karten starten direkt darunter.
// Passt sich per JS dynamisch an, dieser Wert ist nur der CSS-Fallback.
const HEADER_H = 72;
---

<section id="work" class="work-section">

  <!-- ── Sticky header — pinnt wenn die Section oben ankommt ── -->
  <div class="work-header" id="work-header">
    <div class="work-header__inner">
      <div class="work-header__label">
        <span class="work-header__num">01</span>
        <span class="work-header__rule"></span>
        <span class="work-header__title">WORK</span>
      </div>
      <div class="work-header__right">
        <h2 class="work-header__headline">Systems that cannot fail.</h2>
        <p class="work-header__sub">
          Production security engineering. Threat modeling, hardening, incident response.
        </p>
      </div>
      <!-- Card counter: 01 / 04 -->
      <div class="work-header__counter" id="work-counter">
        <span id="work-counter-current">01</span>
        <span class="work-header__counter-sep">/</span>
        <span>{String(projects.length).padStart(2, '0')}</span>
      </div>
    </div>
    <!-- Progress line at bottom of header -->
    <div class="work-header__progress-track">
      <div class="work-header__progress-fill" id="work-progress-fill"></div>
    </div>
  </div>

  <!-- ── Stack — Karten stacken sich unter dem Header auf ── -->
  <div class="work-stack" id="work-stack">
    {projects.map((p, i) => (
      <div
        class="work-card"
        data-card-index={i}
        style={`z-index: ${10 + i}; top: calc(${HEADER_H}px + ${i * 14}px);`}
      >
        <a href={p.href} class="work-card__inner" data-cursor-hover>

          <div class="work-card__left">
            <div class="work-card__meta">
              <span class="work-card__index">{p.index}</span>
              <span class="work-card__tag">{p.tag}</span>
              <span class="work-card__year">{p.year}</span>
            </div>
            <div class="work-card__body">
              <h3 class="work-card__client">
                {p.client}
                <span class="work-card__arrow">→</span>
              </h3>
              <p class="work-card__summary">{p.summary}</p>
              <div class="work-card__role">
                <span class="work-card__role-label">ROLE</span>
                <span class="work-card__role-val">{p.role}</span>
              </div>
            </div>
          </div>

          <div class="work-card__image-wrap">
            {p.image && (
              <div
                class="work-card__image"
                style={`background-image: url("${p.image}")`}
              />
            )}
            <div class="work-card__depth">
              {projects.slice(i + 1).map((_, j) => (
                <span class="work-card__depth-dot" style={`opacity: ${0.25 - j * 0.06}`} />
              ))}
            </div>
          </div>

        </a>
      </div>
    ))}
  </div>

</section>

<style>
  .work-section {
    position: relative;
    border-top: 1px solid rgba(243, 241, 236, 0.08);
  }

  /* ── Sticky header ───────────────────────────────────────────────────── */
  .work-header {
    position: sticky;
    top: 0;
    z-index: 50;
    /* Matcht den Body-Hintergrund — so deckt er die stackenden Karten ab */
    background: #050506;
    border-bottom: 1px solid rgba(243, 241, 236, 0.07);
  }

  .work-header__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 18px 40px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .work-header__label {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--ink-low);
  }

  .work-header__num,
  .work-header__title {
    color: var(--ink);
  }

  .work-header__rule {
    display: block;
    width: 24px;
    height: 1px;
    background: rgba(243, 241, 236, 0.16);
  }

  .work-header__right {
    display: flex;
    align-items: baseline;
    gap: 28px;
    flex: 1;
  }

  .work-header__headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(15px, 1.6vw, 20px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    white-space: nowrap;
  }

  .work-header__sub {
    font-family: var(--font-display);
    font-size: 12px;
    line-height: 1.4;
    color: var(--ink-low);
    margin: 0;
    letter-spacing: -0.003em;
  }

  /* Card counter — top right of header */
  .work-header__counter {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--ink-low);
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    flex-shrink: 0;
  }

  #work-counter-current {
    color: var(--ink);
    transition: opacity 0.2s ease;
  }

  .work-header__counter-sep {
    opacity: 0.3;
  }

  /* Progress line */
  .work-header__progress-track {
    height: 1px;
    width: 100%;
    background: rgba(243, 241, 236, 0.06);
  }

  .work-header__progress-fill {
    height: 100%;
    width: 0%;
    background: #2E6BFF;
    transition: width 80ms linear;
  }

  /* ── Stack ───────────────────────────────────────────────────────────── */
  .work-stack {
    max-width: 1440px;
    margin: 0 auto;
    padding: 20px 40px 120px;
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .work-card {
    position: sticky;
    /* top set inline: header height + stagger per card */
    margin-bottom: 20px;
    will-change: transform;
    transform-origin: top center;
  }

  .work-card__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: stretch;
    background: #0d0d0e;
    border: 1px solid rgba(243, 241, 236, 0.08);
    border-radius: 12px;
    padding: 48px 48px 48px 52px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s ease, background 0.4s ease;
    min-height: 300px;
  }

  .work-card__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(243, 241, 236, 0.015);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    border-radius: 12px;
  }

  .work-card__inner:hover { border-color: rgba(243, 241, 236, 0.16); }
  .work-card__inner:hover::before { opacity: 1; }
  .work-card__inner:hover .work-card__client { transform: translateX(8px); }
  .work-card__inner:hover .work-card__arrow { opacity: 1; transform: translateX(0); }
  .work-card__inner:hover .work-card__image {
    transform: scale(1.04);
    filter: saturate(0.75) brightness(0.9) contrast(1.05);
  }

  .work-card__left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }

  .work-card__meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .work-card__index {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-low);
  }

  .work-card__tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid rgba(243, 241, 236, 0.12);
    border-radius: 100px;
    color: rgba(243, 241, 236, 0.35);
  }

  .work-card__year {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-low);
    margin-left: auto;
  }

  .work-card__body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .work-card__client {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 3.5vw, 52px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 20px;
    transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .work-card__arrow {
    font-size: clamp(24px, 2.5vw, 36px);
    color: var(--accent, #2E6BFF);
    opacity: 0;
    transform: translateX(-12px);
    transition:
      opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .work-card__summary {
    font-family: var(--font-display);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-mid);
    margin: 0;
    max-width: 52ch;
    letter-spacing: -0.005em;
  }

  .work-card__role {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .work-card__role-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-low);
    text-transform: uppercase;
  }

  .work-card__role-val {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
  }

  .work-card__image-wrap {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(243, 241, 236, 0.04);
  }

  .work-card__image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    filter: saturate(0.5) brightness(0.75) contrast(1.05);
    transition:
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 700ms cubic-bezier(0.22, 1, 0.36, 1);
    min-height: 220px;
  }

  .work-card__depth {
    position: absolute;
    bottom: 12px;
    right: 16px;
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .work-card__depth-dot {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(243, 241, 236, 0.6);
  }

  @media (max-width: 900px) {
    .work-card__inner { grid-template-columns: 1fr; }
    .work-card__image-wrap { height: 200px; }
    .work-stack { padding: 16px 16px 80px; }
    .work-header__right { display: none; }
    .work-header__inner { padding: 14px 16px; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section      = document.getElementById('work') as HTMLElement;
  const header       = document.getElementById('work-header') as HTMLElement;
  const progressFill = document.getElementById('work-progress-fill') as HTMLElement;
  const counterEl    = document.getElementById('work-counter-current') as HTMLElement;
  const cards        = document.querySelectorAll<HTMLElement>('.work-card');

  if (!section || !header || !cards.length) throw new Error('WorkSection: missing elements');

  // ── Update card top offsets dynamically based on real header height ────
  // CSS uses the fallback value; JS corrects it after render.
  function updateCardTops() {
    const hh = header.offsetHeight;
    cards.forEach((card, i) => {
      card.style.top = `${hh + i * 14}px`;
    });
  }
  updateCardTops();
  window.addEventListener('resize', updateCardTops);

  // ── Progress bar + counter ─────────────────────────────────────────────
  ScrollTrigger.create({
    trigger: section,
    start: 'top top',
    end: 'bottom bottom',
    onUpdate: (self) => {
      progressFill.style.width = `${self.progress * 100}%`;

      // Update counter to show which card is currently "on top"
      const idx = Math.min(
        Math.floor(self.progress * cards.length),
        cards.length - 1
      );
      counterEl.textContent = String(idx + 1).padStart(2, '0');
    },
  });

  // ── Stacking ───────────────────────────────────────────────────────────
  cards.forEach((card, i) => {

    // Entrance: fade + rise when card first comes into view
    gsap.fromTo(card,
      { opacity: 0, y: 28 },
      {
        opacity: 1, y: 0,
        duration: 0.65,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 92%',
          toggleActions: 'play none none none',
        },
      }
    );

    if (i === 0) return; // first card has nothing beneath it to squish

    // When card i reaches its sticky point, push previous cards back
    ScrollTrigger.create({
      trigger: card,
      start: () => `top ${header.offsetHeight + i * 14}px`,
      onEnter: () => {
        for (let j = 0; j < i; j++) {
          const depth = i - j;
          gsap.to(cards[j], {
            scale: 1 - depth * 0.028,
            y: -(depth * 8),
            duration: 0.45,
            ease: 'power2.out',
          });
        }
      },
      onLeaveBack: () => {
        for (let j = 0; j < i; j++) {
          const prevDepth = Math.max(0, (i - 1) - j);
          gsap.to(cards[j], {
            scale: prevDepth === 0 ? 1 : 1 - prevDepth * 0.028,
            y: prevDepth === 0 ? 0 : -(prevDepth * 8),
            duration: 0.4,
            ease: 'power2.out',
          });
        }
      },
    });
  });
</script>
