---
// WorkScene.astro — one work entry row with hover-image reveal
interface Props {
  index: string;
  client: string;
  role: string;
  year: string;
  summary: string;
  href?: string;
  image?: string;
}
const { index, client, role, year, summary, href = '#', image } = Astro.props;
---

<a href={href} class="work-row" data-work-row data-reveal="fade-up">
  <div class="grid">
    <div class="idx">{index}</div>
    <div class="body">
      <div class="client-wrap">
        <div class="client">{client}</div>
        <span class="arrow">→</span>
      </div>
      <p class="summary">{summary}</p>
    </div>
    <div class="role">
      <span class="muted">ROLE</span>
      <span class="val">{role}</span>
    </div>
    <div class="year">{year}</div>
  </div>
  {image && (
    <div class="hover-image" aria-hidden="true">
      <div class="hover-image-inner" style={`background-image: url("${image}")`}></div>
    </div>
  )}
</a>

<style>
  .work-row {
    position: relative;
    display: block;
    padding: 56px 40px;
    border-top: 1px solid rgba(243, 241, 236, 0.08);
    transition: padding 800ms cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }
  .work-row::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(243, 241, 236, 0.02);
    opacity: 0;
    transition: opacity 800ms cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .work-row:hover::before { opacity: 1; }
  .work-row:hover .client { transform: translateX(32px); }
  .work-row:hover .arrow { opacity: 1; transform: translateX(0); }
  .work-row:hover .year { opacity: 1; }

  .grid {
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 80px 1fr 200px 120px;
    gap: 32px;
    align-items: baseline;
  }
  .idx {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--ink-low);
  }
  .client-wrap {
    display: flex;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 14px;
  }
  .client {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    transition: transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .arrow {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.2vw, 44px);
    color: var(--accent);
    opacity: 0;
    transform: translateX(-16px);
    transition:
      opacity 900ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .summary {
    font-family: var(--font-display);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-mid);
    margin: 0;
    max-width: 54ch;
    letter-spacing: -0.005em;
  }
  .role {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-mid);
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .role .muted { color: var(--ink-low); }
  .role .val { color: var(--ink); }
  .year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    text-align: right;
    opacity: 0.4;
    transition: opacity 800ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* hover-image: 320x200 card that follows cursor */
  .hover-image {
    position: fixed;
    top: 0;
    left: 0;
    width: 360px;
    height: 240px;
    pointer-events: none;
    z-index: 40;
    opacity: 0;
    transform: translate3d(-50%, -50%, 0) scale(0.88);
    transition:
      opacity 500ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
    will-change: transform, opacity;
  }
  .work-row:hover .hover-image {
    opacity: 1;
    transform: translate3d(-50%, -50%, 0) scale(1);
  }
  .hover-image-inner {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    filter: saturate(0.65) brightness(0.85) contrast(1.05);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 48px 1fr; }
    .role, .year { display: none; }
    .hover-image { display: none; }
  }
</style>

<script>
  // Follow cursor with the hover image (for rows that have one)
  const rows = document.querySelectorAll('[data-work-row]') as NodeListOf<HTMLElement>;
  rows.forEach((row) => {
    const img = row.querySelector('.hover-image') as HTMLElement | null;
    if (!img) return;
    row.addEventListener('mousemove', (e) => {
      img.style.left = `${(e as MouseEvent).clientX}px`;
      img.style.top = `${(e as MouseEvent).clientY}px`;
    });
  });
</script>
