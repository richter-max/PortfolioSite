---
// Footer.astro
const socials = [
  { label: 'GITHUB',   href: 'https://github.com/richter-max' },
  { label: 'LINKEDIN', href: 'https://www.linkedin.com/in/maximilian-richter-40697a298' },
  { label: 'STRAVA',   href: 'https://strava.app.link/mIlXsvnJL1b' },
  { label: 'BLOG',     href: '/blog' },
  { label: 'RSS',      href: '/rss.xml' },
];
const legal = [
  { label: 'IMPRESSUM',   href: '/impressum' },
  { label: 'DATENSCHUTZ', href: '/datenschutz' },
  { label: 'SECURITY',    href: '/security' },
];
---

<footer class="site-footer">
  <div class="inner">
    <div class="tagline">
      Open for the<br />right work.
    </div>
    <div class="row">
      <div class="mark">MR.</div>
      <div class="socials">
        {socials.map((s) => {
          const external = s.href.startsWith('http');
          return external
            ? <a href={s.href} target="_blank" rel="noreferrer">{s.label} →</a>
            : <a href={s.href}>{s.label} →</a>;
        })}
      </div>
      <div class="copy">
        © 2026 Maximilian Richter<br />
        Engineering · security · athletic partnerships · Germany
      </div>
    </div>
    <div class="legal-row">
      <nav class="legal-links" aria-label="Legal">
        {legal.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 96px 40px 48px;
    border-top: 1px solid rgba(243, 241, 236, 0.08);
  }
  .inner { max-width: 1440px; margin: 0 auto; }
  .tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
    max-width: 14ch;
  }
  .row {
    margin-top: 64px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
    flex-wrap: wrap;
    border-top: 1px solid rgba(243, 241, 236, 0.08);
    padding-top: 40px;
  }
  .mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .socials { display: flex; gap: 28px; }
  .socials a {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-mid);
  }
  .copy {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-low);
    text-align: right;
  }
  .legal-row {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(243, 241, 236, 0.06);
  }
  .legal-links {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .legal-links a {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-low);
    transition: color 0.2s ease;
  }
  .legal-links a:hover { color: var(--ink); }
</style>
