---
// Nav.astro — fixed translucent top bar
// Items map 1:1 to section IDs in index.astro:
//   WORK    → #work      (WorkSection)
//   FIELD   → #field     (FieldTape)
//   STATS   → #numbers   (MassiveNumbers — uses id="numbers")
//   BLOG    → #blog      (BlogDrift)
//   CONTACT → #contact   (ContactScene)
//
// Active state is determined live via IntersectionObserver —
// no manual `section` prop needed, but it still works as fallback.
interface Props {
  section?: string;
}
// Auto-derive ABOUT highlight from the URL so individual pages don't
// have to remember to pass the prop. Other pages still pass section
// when they want explicit control.
const path = Astro.url.pathname;
const inferredSection = path.startsWith('/about') ? 'ABOUT' : 'HOME';
const { section = inferredSection } = Astro.props;

const items = [
  { label: 'WORK',    id: 'work' },
  { label: 'FIELD',   id: 'field' },
  { label: 'STATS',   id: 'numbers' },
  { label: 'BLOG',    id: 'blog' },
  { label: 'CONTACT', id: 'contact' },
];

// Cross-page link to /about — sits beside the section-anchor row but
// uses a dedicated href, not `/#about`, so the IntersectionObserver
// doesn't try to track a section that doesn't exist on the home page.
const aboutHref = '/about';
---

<nav class="site-nav" data-section={section}>
  <a href="/#top" class="nav-mark">MR.</a>
  <div class="nav-items">
    {items.map((it) => (
      <a
        href={`/#${it.id}`}
        class:list={['nav-link', 'mask-link', { active: section === it.label }]}
        data-nav-target={it.id}
        data-link-text={it.label}
      >
        <span class="mask-link__t">{it.label}</span>
      </a>
    ))}
    <span class="nav-sep" aria-hidden="true"></span>
    <a
      href={aboutHref}
      class:list={['nav-link', 'mask-link', { active: section === 'ABOUT' }]}
      data-link-text="ABOUT"
    >
      <span class="mask-link__t">ABOUT</span>
    </a>
  </div>
  <button
    type="button"
    class="nav-cmdk"
    aria-label="Open command palette"
    data-cmdk-trigger
  >
    <span class="nav-cmdk__keys">
      <span class="kbd-set kbd-set--mac">
        <kbd>⌘</kbd><kbd>K</kbd>
      </span>
      <span class="kbd-set kbd-set--pc">
        <kbd>Ctrl</kbd><kbd>K</kbd>
      </span>
    </span>
    <span class="nav-cmdk__label" aria-hidden="true">SEARCH</span>
  </button>

  <div class="nav-status">
    <span class="nav-dot"></span>
    ALLGÄU · CET
  </div>
</nav>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 72px;
    z-index: 100;
    /* Explicit grid: mark | section-links | cmdk | status.
       The 1fr column eats the space between the brand mark and the
       right-hand cluster, which is what was clipping into "MR." with
       the previous flex+space-between+margin-auto combo. */
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    column-gap: 32px;
    padding: 0 40px;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 600ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 600ms cubic-bezier(0.22, 1, 0.36, 1),
      backdrop-filter 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .site-nav.scrolled {
    background: rgba(5, 5, 6, 0.6);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid rgba(243, 241, 236, 0.08);
  }
  .nav-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
  }
  .nav-items {
    display: flex;
    gap: 28px;
    justify-content: center;
    align-items: center;
  }
  .nav-sep {
    width: 1px;
    height: 14px;
    background: rgba(243, 241, 236, 0.16);
    display: inline-block;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-mid);
    text-decoration: none;
  }
  /* Active = mask-link suppression so the bright label doesn't flicker
     when the IntersectionObserver re-affirms the current section every
     few hundred ms. */
  .nav-link.active { color: var(--ink); }
  .nav-link.active .mask-link__t { color: var(--ink); }
  .nav-link.active::before { display: none; }
  .nav-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-mid);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    display: inline-block;
  }

  /* ⌘K trigger — discoverability hint for the command palette.
     The whole row is clickable; on touch it's a search button, on
     desktop it doubles as a kbd-shortcut affordance. */
  .nav-cmdk {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 10px 5px 8px;
    background: transparent;
    border: 1px solid rgba(243, 241, 236, 0.10);
    border-radius: 6px;
    color: var(--ink-mid);
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .nav-cmdk:hover {
    border-color: rgba(243, 241, 236, 0.24);
    color: var(--ink);
    background: rgba(243, 241, 236, 0.03);
  }
  .nav-cmdk__keys {
    display: inline-flex;
    gap: 2px;
  }
  /* Two key-sets render in the markup; .is-pc on <html> swaps them.
     Default state shows the Mac glyphs because the inline detection
     script only adds .is-pc when the platform is non-Apple, so on
     iOS / macOS the default render is already correct without a
     class flip flicker. */
  .kbd-set {
    display: inline-flex;
    gap: 2px;
  }
  .kbd-set--pc { display: none; }
  :global(html.is-pc) .kbd-set--mac { display: none; }
  :global(html.is-pc) .kbd-set--pc  { display: inline-flex; }

  .nav-cmdk__keys kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border: 1px solid rgba(243, 241, 236, 0.12);
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: var(--ink-mid);
  }
  .nav-cmdk:hover .nav-cmdk__keys kbd {
    border-color: rgba(243, 241, 236, 0.28);
    color: var(--ink);
  }
  .nav-cmdk__label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    color: inherit;
  }

  /* Mobile: hide middle items, keep mark + status */
  @media (max-width: 720px) {
    .nav-items {
      gap: 14px;
    }
    .nav-link {
      font-size: 9px;
      letter-spacing: 0.12em;
    }
    .nav-status {
      display: none;
    }
    .nav-cmdk { margin-right: 0; padding: 5px 8px; }
    .nav-cmdk__label { display: none; }
  }
  @media (max-width: 480px) {
    .site-nav { padding: 0 16px; }
    .nav-items { gap: 10px; }
  }
</style>

<script>
  // Scroll state (transparent → blurred bar)
  const nav = document.querySelector('.site-nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ⌘K trigger button → opens the React command-palette island via
  // the global it registers on mount. window.__openCmdk is set up by
  // CommandPalette.jsx; the trigger may render before the island has
  // hydrated, so we fall back to dispatching the keyboard shortcut.
  document.addEventListener('click', (e) => {
    const t = (e.target as Element)?.closest('[data-cmdk-trigger]');
    if (!t) return;
    e.preventDefault();
    if (typeof (window as any).__openCmdk === 'function') {
      (window as any).__openCmdk();
    } else {
      // Island not hydrated yet — synthesize a Cmd+K key event.
      document.dispatchEvent(new KeyboardEvent('keydown', {
        key: 'k', metaKey: true, bubbles: true,
      }));
    }
  });

  // Active-section tracking via IntersectionObserver.
  // Marks the link whose section is currently most visible.
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link[data-nav-target]');
  const sectionIds = Array.from(navLinks).map(a => a.dataset.navTarget!);
  const sections: Element[] = sectionIds
    .map(id => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  if (sections.length > 0) {
    // Track intersection ratios for each section, pick the one with highest
    const ratios = new Map<Element, number>();
    sections.forEach(s => ratios.set(s, 0));

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          ratios.set(entry.target, entry.intersectionRatio);
        });
        // Find section with max visibility
        let maxRatio = 0;
        let maxSection: Element | null = null;
        ratios.forEach((ratio, section) => {
          if (ratio > maxRatio) {
            maxRatio = ratio;
            maxSection = section;
          }
        });
        // Update active class
        navLinks.forEach(link => {
          const targetId = link.dataset.navTarget;
          const isActive = maxSection && (maxSection as HTMLElement).id === targetId;
          link.classList.toggle('active', !!isActive);
        });
      },
      {
        // Fire as sections enter/leave the middle band of the viewport
        rootMargin: '-40% 0px -40% 0px',
        threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
      }
    );

    sections.forEach(s => observer.observe(s));
  }
</script>
