---
import { projects } from '@data/projects';
import WorkCardVisual from './WorkCardVisual.astro';
---

<section id="work" class="work-section">

  <!-- ── Header: sticky so the moment it pins, cards start stacking ── -->
  <div class="work-header" id="work-header">
    <div class="work-header__label">
      <span class="work-header__num">01</span>
      <span class="work-header__rule"></span>
      <span class="work-header__title">WORK</span>
    </div>
    <h2 class="work-header__headline">Projects.</h2>
    <p class="work-header__sub">
      Production security engineering. Threat modeling,<br />
      hardening, incident response. Selected engagements below.
    </p>
  </div>

  <!-- ── Cards stack directly beneath the pinned header ── -->
  <div class="work-stack" id="work-stack">
    {projects.map((p, i) => {
      const linkable = !!p.href;
      const Inner = linkable ? 'a' : 'div';
      const innerProps = linkable
        ? { href: p.href, 'data-cursor-hover': true }
        : { 'aria-disabled': 'true' };
      const csSlug = linkable ? (p.href.split('/').filter(Boolean).pop() ?? '') : '';
      return (
      <div
        class={`work-card ${linkable ? '' : 'work-card--unlinked'}`}
        data-card-index={i}
        style={`z-index: ${10 + i};`}
      >
        <Inner class="work-card__inner" {...innerProps}>

          <div class="work-card__left">
            <div class="work-card__meta">
              <span class="work-card__index">{p.index}</span>
              <span class="work-card__tag">{p.tag}</span>
              <span class="work-card__year">{p.year}</span>
            </div>
            <div class="work-card__body">
              <h3
                class="work-card__client"
                transition:name={csSlug ? `cs-title-${csSlug}` : undefined}
              >
                {p.client}
                {linkable && <span class="work-card__arrow">→</span>}
              </h3>
              <p class="work-card__summary">{p.summary}</p>
              <div class="work-card__role">
                <span class="work-card__role-label">ROLE</span>
                <span class="work-card__role-val">{p.role}</span>
              </div>
            </div>
          </div>

          <!-- Project-specific visual (or image fallback) -->
          <div class="work-card__visual-wrap">
            <WorkCardVisual project={p} />
            <div class="work-card__depth">
              {projects.slice(i + 1).map((_, j) => (
                <span class="work-card__depth-dot" style={`opacity: ${0.25 - j * 0.06}`} />
              ))}
            </div>
          </div>

        </Inner>
      </div>
    );
    })}
  </div>

</section>

<style>
  .work-section {
    position: relative;
  }

  /* ── Header: sticky, background covers cards scrolling beneath ───────── */
  .work-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    padding: 128px 40px 80px;
  }

  .work-header__label,
  .work-header__headline,
  .work-header__sub {
    max-width: var(--max-content);
    margin-left: auto;
    margin-right: auto;
  }

  .work-header__label {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--ink-low);
  }

  .work-header__num,
  .work-header__title {
    color: var(--ink);
  }

  .work-header__rule {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--hairline-strong);
  }

  .work-header__headline {
    display: block;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 auto 28px;
  }

  .work-header__sub {
    display: block;
    font-family: var(--font-display);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-mid);
    margin: 0 auto;
    letter-spacing: -0.005em;
  }

  /* ── Stack ───────────────────────────────────────────────────────────── */
  .work-stack {
    padding: 20px 40px 120px;
    max-width: var(--max-content);
    margin: 0 auto;
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .work-card {
    position: sticky;
    margin-bottom: 20px;
    will-change: transform;
    transform-origin: top center;
  }

  .work-card__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: stretch;
    background: #0d0d0e;
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 48px 48px 48px 52px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s ease, background 0.4s ease;
    min-height: 300px;
  }

  .work-card__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(243, 241, 236, 0.015);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    border-radius: 12px;
  }

  .work-card__inner:hover { border-color: var(--hairline-strong); }
  .work-card__inner:hover::before { opacity: 1; }
  .work-card__inner:hover .work-card__client { transform: translateX(8px); }
  .work-card__inner:hover .work-card__arrow { opacity: 1; transform: translateX(0); }

  .work-card__left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }

  .work-card__meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .work-card__index {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-low);
  }

  .work-card__tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid var(--hairline-strong);
    border-radius: 100px;
    color: rgba(243, 241, 236, 0.35);
  }

  .work-card__year {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-low);
    margin-left: auto;
  }

  .work-card__body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .work-card__client {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 3.5vw, 52px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 20px;
    transition: transform 700ms var(--ease-out-expo);
  }

  .work-card__arrow {
    font-size: clamp(24px, 2.5vw, 36px);
    color: var(--accent);
    opacity: 0;
    transform: translateX(-12px);
    transition:
      opacity 700ms var(--ease-out-expo),
      transform 700ms var(--ease-out-expo);
  }

  .work-card__summary {
    font-family: var(--font-display);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-mid);
    margin: 0;
    max-width: 52ch;
    letter-spacing: -0.005em;
  }

  .work-card__role {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .work-card__role-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-low);
    text-transform: uppercase;
  }

  .work-card__role-val {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
  }

  /* ── Visual wrap (replaces old image-wrap) ─────────────────────────── */
  .work-card__visual-wrap {
    position: relative;
    border-radius: 8px;
    min-height: 220px;
  }

  .work-card__depth {
    position: absolute;
    bottom: 12px;
    right: 16px;
    display: flex;
    gap: 5px;
    align-items: center;
    z-index: 2;
    pointer-events: none;
  }

  .work-card__depth-dot {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(243, 241, 236, 0.6);
  }

  @media (max-width: 900px) {
    .work-card__inner { grid-template-columns: 1fr; }
    .work-card__visual-wrap { height: 200px; }
    .work-stack { padding: 16px 16px 80px; }
    .work-header { padding: 80px 16px 48px; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const header = document.getElementById('work-header') as HTMLElement;
  const cards  = document.querySelectorAll<HTMLElement>('.work-card');

  if (!header || !cards.length) throw new Error('WorkSection: missing elements');

  function setCardTops() {
    const hh = header.offsetHeight;
    cards.forEach((card, i) => {
      card.style.top = `${hh + i * 14}px`;
    });
    ScrollTrigger.refresh();
  }

  setCardTops();
  window.addEventListener('resize', setCardTops);
  document.fonts.ready.then(setCardTops);

  cards.forEach((card) => {
    gsap.fromTo(card,
      { opacity: 0, y: 28 },
      {
        opacity: 1, y: 0,
        duration: 0.65,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 92%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  cards.forEach((card, i) => {
    if (i === 0) return;

    ScrollTrigger.create({
      trigger: card,
      start: () => `top ${header.offsetHeight + i * 14}px`,

      onEnter: () => {
        for (let j = 0; j < i; j++) {
          const depth = i - j;
          gsap.to(cards[j], {
            scale: 1 - depth * 0.028,
            y: -(depth * 8),
            duration: 0.45,
            ease: 'power2.out',
          });
        }
      },

      onLeaveBack: () => {
        for (let j = 0; j < i; j++) {
          const prevDepth = Math.max(0, (i - 1) - j);
          gsap.to(cards[j], {
            scale: prevDepth === 0 ? 1 : 1 - prevDepth * 0.028,
            y: prevDepth === 0 ? 0 : -(prevDepth * 8),
            duration: 0.4,
            ease: 'power2.out',
          });
        }
      },
    });
  });
</script>
