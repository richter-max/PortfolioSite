---
/**
 * TerminalVisual — Scanner-style typed terminal output.
 *
 * Idle: command line shown, cursor blinks. Hover: lines type in sequence,
 * final result line highlights. Pure CSS animations (no GSAP needed) for
 * predictability; intersection-observer triggers initial reveal.
 */
import type { TerminalVisual as TerminalData } from '@data/projects';

interface Props {
  data: TerminalData;
}

const { data } = Astro.props;
---

<div class="terminal" data-terminal>
  <div class="terminal__bar">
    <div class="terminal__dots">
      <span /><span /><span />
    </div>
    <span class="terminal__title">scanner.sh</span>
  </div>

  <div class="terminal__body">
    <div class="terminal__line terminal__cmd">
      <span class="terminal__prompt">$</span>
      <span class="terminal__cmd-text">{data.command}</span>
      <span class="terminal__cursor" aria-hidden="true" />
    </div>

    <div class="terminal__output">
      {data.lines.map((line, i) => (
        <div
          class="terminal__line terminal__out-line"
          style={`--line-delay: ${(i + 1) * 220}ms`}
        >
          {line}
        </div>
      ))}
      <div
        class="terminal__line terminal__final"
        style={`--line-delay: ${(data.lines.length + 1) * 220}ms`}
      >
        {data.finalLine}
      </div>
    </div>
  </div>
</div>

<style>
  .terminal {
    width: 100%;
    height: 100%;
    min-height: 220px;
    background: var(--bg-2);
    border: 1px solid var(--hairline);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: var(--font-mono);
  }

  /* ── Header bar ──────────────────────────────────────────────────── */
  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: rgba(243, 241, 236, 0.02);
    border-bottom: 1px solid var(--hairline);
  }

  .terminal__dots {
    display: flex;
    gap: 5px;
  }

  .terminal__dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(243, 241, 236, 0.18);
  }

  .terminal__title {
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-low);
    text-transform: uppercase;
  }

  /* ── Body ────────────────────────────────────────────────────────── */
  .terminal__body {
    flex: 1;
    padding: 14px 16px;
    font-size: 11px;
    line-height: 1.7;
    color: var(--ink-dim);
    overflow: hidden;
  }

  .terminal__line {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .terminal__cmd {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .terminal__prompt {
    color: var(--accent);
    font-weight: 600;
  }

  /* Idle-state cursor — blinks always */
  .terminal__cursor {
    display: inline-block;
    width: 7px;
    height: 13px;
    background: var(--ink);
    margin-left: 2px;
    animation: blink 1.1s steps(1) infinite;
    vertical-align: middle;
  }

  @keyframes blink {
    0%, 50%   { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Output lines — hidden by default, revealed on hover */
  .terminal__output {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .terminal__out-line {
    color: var(--ink-mid);
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 280ms var(--ease-out-expo),
      transform 280ms var(--ease-out-expo);
  }

  .terminal__final {
    color: var(--signal-ok);
    margin-top: 8px;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 280ms var(--ease-out-expo),
      transform 280ms var(--ease-out-expo);
    letter-spacing: 0.02em;
  }

  /* ── Hover: cascade output lines ────────────────────────────────── */
  :global(.work-card__inner:hover) .terminal__out-line,
  :global(.work-card__inner:hover) .terminal__final {
    opacity: 1;
    transform: translateX(0);
    transition-delay: var(--line-delay);
  }

  /* When hover ends, snap back without delay so re-hover replays cleanly */
  :global(.work-card__inner:not(:hover)) .terminal__out-line,
  :global(.work-card__inner:not(:hover)) .terminal__final {
    transition-delay: 0ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal__cursor { animation: none; opacity: 1; }
    .terminal__out-line, .terminal__final {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
