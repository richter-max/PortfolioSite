---
// /about — type-driven editorial portrait page.
//
// Decisions:
//   - The master portrait is only 458×554 px, so we treat it as a
//     small detail element (max ~240 px wide) inside a bio card.
//     Trying to use it as a hero photograph reads as a low-resolution
//     upscale; the page now leans on type, layout and live data
//     instead.
//   - The page reads as five layered moments rather than a single
//     scroll: intro (manifesto), now (live status), story, bio
//     card, principles, closing. Each section breaks rhythm
//     deliberately — alternating widths, alternating accent — so the
//     scroll never feels uniform.
//
// Live data:
//   - sessionsThisYear / streakWeeks / commits30d are read from the
//     same live-stats.json the home page uses, so the about page
//     ages with the rest of the site.
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/layout/Nav.astro';
import Rail from '@components/layout/Rail.astro';
import Footer from '@components/layout/Footer.astro';
import liveStats from '@data/live-stats.json';

const streakWeeks      = liveStats.strava?.streakWeeks      ?? 0;
const sessionsThisYear = liveStats.strava?.sessionsThisYear ?? 0;
const commits30d       = liveStats.github?.commits30d       ?? 0;
const updatedAt        = liveStats.updatedAt                ?? null;
const latestRepo       = liveStats.github?.latestRepo       ?? null;
const lastRun          = liveStats.strava?.lastRun          ?? null;

function hoursAgo(iso) {
  if (!iso) return '—';
  const diffH = Math.max(0, (Date.now() - Date.parse(iso)) / 3600000);
  if (diffH < 1)   return 'JUST NOW';
  if (diffH < 24)  return `${Math.round(diffH)}H AGO`;
  return `${Math.round(diffH / 24)}D AGO`;
}

// "Habits" — first-person, low-key. Avoid grind-talk: no "discipline",
// "earned that trust", "the accumulation is the work", "matters more
// than any single sprint". The voice should read as "this is just
// what I happen to do" rather than "this is what I work hard at".
const principles = [
  {
    n: '01',
    title: 'I write the trace first.',
    body: "Every benchmark drops one JSONL line per event before anything gets aggregated. Makes it easy to ask new questions later.",
  },
  {
    n: '02',
    title: 'I stack thin layers.',
    body: "Three cheap guards in series catch more than one expensive filter does on its own. Same idea works in training — easy weeks and hard weeks, not constant medium ones.",
  },
  {
    n: '03',
    title: 'I sandbox before I integrate.',
    body: "Mocked tools, deterministic runs, no real side effects until everything's settled. A security tool that can break its own host isn't worth much.",
  },
  {
    n: '04',
    title: 'I keep arcs finishable.',
    body: "Half before full. Demo before live model. Each step gets to be a thing on its own first.",
  },
  {
    n: '05',
    title: 'I aim for one shipped thing a quarter.',
    body: "Case study, open-source release, race finish — whatever's ready. Nothing dramatic, just keeps things moving.",
  },
];

// Bio card key:value rows. Compact mono table, not a paragraph.
const bio = [
  ['BORN',     '2004 · Sonthofen'],
  ['BASED',    'Allgäu · CET (UTC+1)'],
  ['EDUCATED', 'Ausbildung · Application Developer'],
  ['FOCUS',    'AI agent security · Pen-test tooling'],
  ['STACK',    'Python · TypeScript · Three.js · GSAP'],
  ['TRAINING', 'Running · Triathlon · Table tennis'],
  ['REACH',    'max.richter.dev@proton.me'],
];
---

<BaseLayout
  title="About — Maximilian Richter"
  description="Security engineer working on AI-agent harness research. Endurance athlete training for IRONMAN 70.3 Kraichgau. Based in the Allgäu."
  ogImage="/img/og-default.jpg"
>
  <Nav />
  <Rail />

  <main id="main" class="ab">

    <!-- ── 01 · Manifesto ─────────────────────────────────────────
         Pure-type opener. No photograph. Two stacked moves: a small
         "ABOUT" mark with rule + indexed numeral, then a four-line
         declarative manifesto that does the introducing. Index "A.01"
         in warm accent + thin rule on the right echoes the case-study
         chapter pattern so the page reads as part of the same system.
    -->
    <section class="ab-mani">
      <div class="ab-mani__inner">
        <div class="ab-kicker mono">
          <span class="ab-kicker__num">A.01</span>
          <span class="ab-kicker__rule"></span>
          <span class="ab-kicker__txt">ABOUT</span>
          <span class="ab-kicker__year mono">— 2026</span>
        </div>

        <h1 class="ab-mani__h" data-reveal="lines">
          I build security tools<br/>
          that produce evidence,<br/>
          and I run because<br/>
          <span class="ab-mani__warm">it makes the rest clearer.</span>
        </h1>

        <div class="ab-mani__foot">
          <p class="ab-mani__lede" data-reveal="fade-up">
            Maximilian Richter — security engineer, working on AI-agent
            harnesses and pen-test tooling. Training for IRONMAN 70.3
            Kraichgau on the side. Based in the Allgäu.
          </p>
          <a class="ab-mani__cta" href="#story" data-cursor-hover>
            <span class="ab-mani__cta__lbl">READ THE LONG VERSION</span>
            <span class="ab-mani__cta__arr">↓</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ── 02 · Currently (Now block) ─────────────────────────────
         Fixed-grid mono "telemetry" panel of four cells:
         shipping (latest commit), training (streak + last run),
         ranking (TT rating), reading (manual editorial). Lives behind
         the manifesto so the page transitions from declarative copy
         straight into observable signal.
    -->
    <section class="ab-now">
      <div class="ab-now__inner">
        <header class="ab-now__head">
          <div class="ab-kicker mono">
            <span class="ab-kicker__num">A.02</span>
            <span class="ab-kicker__rule"></span>
            <span class="ab-kicker__txt">NOW</span>
          </div>
          <div class="ab-now__live mono">
            <span class="ab-now__live__dot"></span>
            <span>LIVE — UPDATED {hoursAgo(updatedAt)}</span>
          </div>
        </header>

        <div class="ab-now__grid">
          <div class="ab-now__cell">
            <div class="ab-now__k mono">SHIPPING</div>
            <div class="ab-now__v">
              {latestRepo ? (
                <a href={latestRepo.url} class="ab-now__link" target="_blank" rel="noreferrer" data-cursor-hover>
                  richter-max / <strong>{latestRepo.name}</strong>
                </a>
              ) : 'aegis · open-source'}
            </div>
            {latestRepo?.headline && (
              <div class="ab-now__msg">
                <span class="ab-now__msg__dot"></span>
                <span>{latestRepo.headline}</span>
              </div>
            )}
          </div>

          <div class="ab-now__cell">
            <div class="ab-now__k mono">TRAINING</div>
            <div class="ab-now__v">{streakWeeks}-week streak · {sessionsThisYear} sessions YTD</div>
            {lastRun && (
              <div class="ab-now__msg">
                <span class="ab-now__msg__dot ab-now__msg__dot--warm"></span>
                <span>Last run · {lastRun.weekday} · {lastRun.km} km</span>
              </div>
            )}
          </div>

          <div class="ab-now__cell">
            <div class="ab-now__k mono">CADENCE</div>
            <div class="ab-now__v ab-now__v--num"><span data-count={commits30d}>0</span></div>
            <div class="ab-now__msg"><span>contributions · last 30 days</span></div>
          </div>

          <div class="ab-now__cell">
            <div class="ab-now__k mono">NEXT</div>
            <div class="ab-now__v ab-now__v--warm">IRONMAN 70.3 · Kraichgau</div>
            <div class="ab-now__msg"><span>31 May 2026 · 1.9 swim · 90 bike · 21.1 run</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 03 · Bio card ──────────────────────────────────────────
         Editorial passport-style card: small portrait at left,
         mono-table on the right with seven key/value rows. The
         small portrait size (max 240 px) matches the master's native
         resolution so the asset stays sharp.
    -->
    <section class="ab-bio">
      <div class="ab-bio__inner">
        <div class="ab-bio__index mono">
          <span class="ab-bio__index__num">A.03 · BIO</span>
          <span class="ab-bio__index__id mono">M.R · 1999</span>
        </div>

        <div class="ab-bio__card">
          <figure class="ab-bio__portrait" data-reveal="clip">
            <picture>
              <source
                type="image/avif"
                srcset="/img/opt/portrait-field-640.avif 640w, /img/opt/portrait-field-1280.avif 1280w"
                sizes="(max-width: 720px) 220px, (max-width: 1100px) 300px, 360px"
              />
              <source
                type="image/webp"
                srcset="/img/opt/portrait-field-640.webp 640w, /img/opt/portrait-field-1280.webp 1280w"
                sizes="(max-width: 720px) 220px, (max-width: 1100px) 300px, 360px"
              />
              <img
                src="/img/opt/portrait-field-640.jpg"
                srcset="/img/opt/portrait-field-640.jpg 640w, /img/opt/portrait-field-1280.jpg 1280w"
                sizes="(max-width: 720px) 220px, (max-width: 1100px) 300px, 360px"
                alt="Maximilian Richter at a railing in Shenzhen, skyline behind."
                width="1080"
                height="1440"
                loading="lazy"
                decoding="async"
              />
            </picture>
            <figcaption class="ab-bio__cap mono">
              <span class="ab-bio__cap__dot"></span>
              <span>SHENZHEN · 2025</span>
            </figcaption>
          </figure>

          <dl class="ab-bio__list">
            {bio.map(([k, v]) => (
              <div class="ab-bio__row">
                <dt class="mono">{k}</dt>
                <dd>{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <!-- ── 04 · Story ─────────────────────────────────────────────
         Center-set editorial column. Headline at oversized scale,
         drop-cap on the first paragraph, line-length capped to 64ch.
    -->
    <section class="ab-story" id="story">
      <div class="ab-story__inner">
        <div class="ab-kicker mono">
          <span class="ab-kicker__num">A.04</span>
          <span class="ab-kicker__rule"></span>
          <span class="ab-kicker__txt">STORY</span>
        </div>

        <h2 class="ab-h2" data-reveal="lines">
          How I ended up<br/>
          doing both.
        </h2>

        <div class="ab-prose">
          <p data-reveal="fade-up" class="ab-prose__lead">
            <span class="ab-prose__cap">I</span> came into security through tooling, not bug-hunting. The first thing I built that felt right was a small CLI that ran ten reconnaissance steps in one command and dumped a JSONL trace — same reflex I now apply to agent evaluations. The output isn't a verdict, it's evidence the next person can re-run, argue with, and disprove.
          </p>
          <p data-reveal="fade-up">
            The endurance side started in parallel. Long sessions made the same point the engineering already wanted: a 90-minute run that's well paced gets you further than a 60-minute hero run that flames out. A guard layer that's auditable is more useful than a black-box filter with a higher single-metric score. Different vocabulary, same shape.
          </p>
          <p data-reveal="fade-up">
            Most of what's on this site I work on solo. One artifact a quarter — case study, open-source release, or a race — and over time it adds up. Nothing dramatic about it.
          </p>
        </div>
      </div>
    </section>

    <!-- ── 05 · Principles ────────────────────────────────────────
         Numbered list, generous vertical rhythm, hairline rules.
         Numerals carry the warm accent so the rule-set ties to the
         endurance side of the brand.
    -->
    <section class="ab-prn">
      <div class="ab-prn__inner">
        <header class="ab-prn__head">
          <div class="ab-kicker mono">
            <span class="ab-kicker__num">A.05</span>
            <span class="ab-kicker__rule"></span>
            <span class="ab-kicker__txt">PRACTICE</span>
          </div>
          <div class="ab-prn__count mono">FIVE HABITS</div>
        </header>

        <h2 class="ab-h2 ab-prn__h" data-reveal="lines">
          How the work<br/>
          actually runs.
        </h2>

        <ol class="ab-prn__list" data-stagger-children>
          {principles.map((p) => (
            <li class="ab-prn__item">
              <div class="ab-prn__num mono">{p.n}</div>
              <div class="ab-prn__body">
                <h3 class="ab-prn__title">{p.title}</h3>
                <p class="ab-prn__copy">{p.body}</p>
              </div>
              <div class="ab-prn__arrow mono">→</div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ── 06 · Closing ───────────────────────────────────────────
         Two-column closing block: oversized statement on the left,
         CTAs + "elsewhere" social pointers on the right. Sits on the
         warm dark surface so the section reads as an emotional close
         instead of more page-body.
    -->
    <section class="ab-close">
      <div class="ab-close__inner">
        <p class="ab-close__copy" data-reveal="lines">
          If any of this matches<br/>
          the kind of work you<br/>
          want done — <span class="ab-close__warm">write me.</span>
        </p>

        <div class="ab-close__side">
          <div class="ab-close__row">
            <a href="/#contact" class="ab-close__btn" data-magnetic="0.4" data-cursor-hover>
              <span data-magnetic-label>OPEN A CONVERSATION →</span>
            </a>
          </div>
          <div class="ab-close__sub mono">
            <a href="/case-studies/aegis" data-cursor-hover>AEGIS CASE STUDY →</a>
            <a href="/blog" data-cursor-hover>FIELD NOTES →</a>
          </div>
          <ul class="ab-close__else mono">
            <li><span>GITHUB</span><a href="https://github.com/richter-max" target="_blank" rel="noreferrer">@richter-max ↗</a></li>
            <li><span>LINKEDIN</span><a href="https://www.linkedin.com/in/maximilian-richter-40697a298" target="_blank" rel="noreferrer">in/maximilian-richter ↗</a></li>
            <li><span>STRAVA</span><a href="https://strava.app.link/mIlXsvnJL1b" target="_blank" rel="noreferrer">richter-max ↗</a></li>
            <li><span>EMAIL</span><a href="mailto:max.richter.dev@proton.me">max.richter.dev@proton.me</a></li>
          </ul>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Page frame ───────────────────────────────────────────────── */
  .ab {
    background: var(--bg);
    color: var(--ink);
    overflow: hidden;
  }
  .ab section {
    padding: 0 40px;
    position: relative;
  }
  .ab .mono { font-family: var(--font-mono); }

  .ab-kicker {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--ink-low);
  }
  .ab-kicker__num   { color: var(--accent-warm); font-weight: 600; }
  .ab-kicker__rule  { width: 32px; height: 1px; background: rgba(243, 241, 236, 0.18); }
  .ab-kicker__txt   { color: var(--ink); }
  .ab-kicker__year  { color: var(--ink-low); margin-left: 8px; }

  /* ── 01 · Manifesto ───────────────────────────────────────────── */
  .ab-mani {
    padding-top: 168px;
    padding-bottom: 144px;
    isolation: isolate;
  }
  .ab-mani::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 12% 20%, rgba(232, 181, 87, 0.08), transparent 55%),
      radial-gradient(ellipse at 92% 96%, rgba(46, 107, 255, 0.06), transparent 55%);
    pointer-events: none;
    z-index: -1;
  }
  .ab-mani__inner {
    max-width: 1440px;
    margin: 0 auto;
  }
  .ab-mani__h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(48px, 8vw, 132px);
    line-height: 0.94;
    letter-spacing: -0.045em;
    color: var(--ink);
    margin: 48px 0 80px;
    max-width: 18ch;
  }
  .ab-mani__warm { color: var(--accent-warm); }
  .ab-mani__foot {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 64px;
    align-items: end;
    border-top: 1px solid var(--hairline);
    padding-top: 32px;
  }
  .ab-mani__lede {
    font-family: var(--font-display);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-mid);
    letter-spacing: -0.005em;
    max-width: 56ch;
    margin: 0;
  }
  .ab-mani__cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--ink-mid);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(243, 241, 236, 0.16);
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .ab-mani__cta:hover { color: var(--ink); border-color: var(--ink); }
  .ab-mani__cta__arr { transition: transform 0.25s var(--ease-out-expo); }
  .ab-mani__cta:hover .ab-mani__cta__arr { transform: translateY(4px); }

  /* ── 02 · Now grid ─────────────────────────────────────────────
     Responsive 2×2 grid that stacks at 720px. Each cell has a soft
     hairline border that tightens at hover via accent color so the
     cells feel responsive even though they aren't links by default.
  */
  .ab-now {
    padding-top: 96px;
    padding-bottom: 96px;
    border-top: 1px solid var(--hairline);
    background: rgba(243, 241, 236, 0.015);
  }
  .ab-now__inner {
    max-width: 1440px;
    margin: 0 auto;
  }
  .ab-now__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }
  .ab-now__live {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 12px;
    border: 1px solid rgba(243, 241, 236, 0.12);
    border-radius: 100px;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-mid);
  }
  .ab-now__live__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34,197,94,0.65);
    animation: nowPulse 2.4s ease-in-out infinite;
  }
  @keyframes nowPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.7); }
  }
  .ab-now__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
  }
  .ab-now__cell {
    background: var(--bg);
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 168px;
    transition: background 0.3s ease;
  }
  .ab-now__cell:hover { background: rgba(243, 241, 236, 0.03); }
  .ab-now__k {
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--ink-low);
    margin-bottom: 4px;
  }
  .ab-now__v {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .ab-now__v--num {
    font-weight: 300;
    font-size: 56px;
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
  }
  .ab-now__v--warm { color: var(--accent-warm); }
  .ab-now__link {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ab-now__link:hover { color: var(--accent); }
  .ab-now__link strong { color: var(--accent); font-weight: 500; }
  .ab-now__msg {
    margin-top: auto;
    padding-top: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-mid);
  }
  .ab-now__msg__dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(243, 241, 236, 0.4);
    flex-shrink: 0;
  }
  .ab-now__msg__dot--warm {
    background: var(--accent-warm);
    box-shadow: 0 0 6px rgba(232, 181, 87, 0.5);
  }

  /* ── 03 · Bio card ─────────────────────────────────────────────
     Two-column layout: small portrait (max 260 px) on the left,
     mono-table on the right. The portrait sits in a frame with a
     hairline border + caption at the bottom — feels like a passport
     photo, not a hero. At its native ~458 px master and ~260 px
     render width, the asset stays crisp on hi-DPI screens.
  */
  .ab-bio {
    padding-top: 144px;
    padding-bottom: 144px;
    border-top: 1px solid var(--hairline);
  }
  .ab-bio__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .ab-bio__index {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--ink-low);
    padding-bottom: 24px;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 56px;
  }
  .ab-bio__index__num { color: var(--accent-warm); }
  .ab-bio__index__id  { color: var(--ink); }

  .ab-bio__card {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 72px;
    align-items: start;
  }
  .ab-bio__portrait {
    margin: 0;
    position: relative;
    border-radius: 2px;
    overflow: hidden;
    /* New master is 4284×5712 (3:4 portrait, post-rotation). The old
       4:5-ish ratio was a relic of the placeholder asset. */
    aspect-ratio: 3 / 4;
    background: rgba(243, 241, 236, 0.04);
    border: 1px solid rgba(243, 241, 236, 0.10);
    isolation: isolate;
  }
  .ab-bio__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.78) contrast(1.05);
  }
  .ab-bio__portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(5,5,6,0.7) 100%);
    pointer-events: none;
  }
  .ab-bio__cap {
    position: absolute;
    left: 14px;
    bottom: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 9px;
    letter-spacing: 0.22em;
    color: var(--ink);
  }
  .ab-bio__cap__dot {
    width: 5px; height: 5px;
    background: var(--accent-warm);
    display: inline-block;
  }

  .ab-bio__list {
    margin: 0;
    padding: 0;
    display: grid;
    gap: 16px;
  }
  .ab-bio__row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .ab-bio__row:last-child { border-bottom: none; }
