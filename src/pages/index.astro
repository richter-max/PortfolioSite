---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/layout/Nav.astro';
import Rail from '@components/layout/Rail.astro';
import Footer from '@components/layout/Footer.astro';
import WorkSection from '@components/work/WorkSection.astro';
import MassiveNumbers from '@components/stats/MassiveNumbers.astro';
import BlogDrift from '@components/blog/BlogDrift.astro';
import Hero from '@components/hero/Hero.jsx';
import FieldTape from '@components/field/FieldTape.jsx';
import ContactScene from '@components/contact/ContactScene.jsx';
import { fieldEntries } from '@data/field';
---

<BaseLayout>
  <Nav />
  <Rail />
  <main>
    <Hero client:load />
    <WorkSection />
    <FieldTape entries={fieldEntries} client:visible />
    <MassiveNumbers />
    <BlogDrift />
    <ContactScene client:visible />
    <Footer />
  </main>
</BaseLayout>
