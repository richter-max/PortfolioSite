---
// BaseLayout.astro — document shell, typography, chrome
import '@styles/fonts.css';
import '@styles/tokens.css';
import '@styles/base.css';
import { SITE } from '@data/site';
import { ViewTransitions } from 'astro:transitions';
import CommandPalette from '@components/cmdk/CommandPalette.jsx';
import liveStats from '@data/live-stats.json';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Adds a class to <body>. Used by article layouts to enable
   *  the reading-cursor variant ("is-reading"). */
  bodyClass?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  noindex = false,
  bodyClass = '',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImageAbs = new URL(ogImage, SITE.url).toString();

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  email: `mailto:${SITE.author.email}`,
  jobTitle: 'Security Engineer',
  sameAs: [
    'https://github.com/richter-max',
    'https://www.linkedin.com/in/maximilian-richter-40697a298',
  ],
};

const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'en',
  author: { '@type': 'Person', name: SITE.author.name },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Platform detection runs before the page paints so the Cmd+K
         label in the nav renders with the right modifier glyph (⌘ on
         Apple devices, "Ctrl" elsewhere) without a class-flip flash. -->
    <script is:inline>
      try {
        var ua = navigator.userAgent || navigator.platform || '';
        if (!/Mac|iPhone|iPad|iPod/i.test(ua)) {
          document.documentElement.classList.add('is-pc');
        }
      } catch {}
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={SITE.author.name} />
    <meta name="theme-color" content="#050506" />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Favicon set: SVG primary (scales to any size), PNG fallbacks
         for older browsers + iOS home screen + Android Chrome / PWA. -->
    <link rel="icon"          type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon"          type="image/png"     href="/favicons/favicon-32.png" sizes="32x32" />
    <link rel="icon"          type="image/png"     href="/favicons/favicon-16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest"      href="/site.webmanifest" />

    <!-- Sitemap discovery -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- RSS discovery — picked up by browser address-bar feed icons,
         RSS readers, and feed-aggregator crawlers. -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Blog`}
      href="/rss.xml"
    />

    <!-- fonts: self-hosted variable woff2, preload latin for instant render -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/inter-tight-latin-wght-normal.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/jetbrains-mono-latin-wght-normal.woff2"
      crossorigin
    />

    <!-- preload hero LCP image -->
    <link rel="preload" as="image" href="/img/opt/hero-path-1280.avif" type="image/avif" fetchpriority="high" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />

    <!-- View Transitions — custom lift+blur cross-page choreography
         (overrides defined in <style is:global> below). The default
         Astro fade is too generic for a studio feel; we replace it with
         a 520ms expo-out lift that subtly blurs while crossing. Shared
         elements (case-study titles via transition:name) keep their
         built-in morph behaviour. -->
    <ViewTransitions />
  </head>
  <body class={bodyClass}>

    <a href="#main" class="skip-link">Skip to content</a>

    <!-- ── Grain overlay: animated SVG noise + vignette ───────────────────
         Pure CSS, no JS, no npm. Sits above everything via z-index 1000/999.
         pointer-events: none so it never blocks clicks.
    ──────────────────────────────────────────────────────────────────────── -->
    <div id="grain" aria-hidden="true"></div>
    <div id="vignette" aria-hidden="true"></div>

    <slot />

    <!-- ── Command palette ────────────────────────────────────────────────
         Cmd+K / Ctrl+K opens an overlay search across pages, actions,
         live data and socials. transition:persist so the React island
         hydrates once and survives view transitions. -->
    <CommandPalette live={liveStats} client:idle transition:persist />

    <!-- ── Custom cursor ──────────────────────────────────────────────────
         Dot + lagging ring with magnetic pull on links/buttons.
         transition:persist keeps the SAME DOM nodes across Astro view
         transitions — so script references stay valid and the cursor
         doesn't reset to (0,0) on every page change.
    ──────────────────────────────────────────────────────────────────────── -->
    <div id="cursor-dot"  aria-hidden="true" transition:persist></div>
    <div id="cursor-ring" aria-hidden="true" transition:persist></div>

    <script>
      import '../scripts/motion.js';
    </script>

    <!-- Vercel Web Analytics + Speed Insights — cookie-free, no PII.
         Only emits anonymous page views and Core Web Vitals. -->
    <script>
      import { inject } from '@vercel/analytics';
      import { injectSpeedInsights } from '@vercel/speed-insights';
      inject();
      injectSpeedInsights();
    </script>
  </body>
</html>

<style is:global>
  /* ── View-transition choreography ──────────────────────────────────────
     Customised root transition: a 520ms lift + soft blur in both
     directions, so the page feels like film cuts instead of a fade. The
     ::view-transition pseudo tree only exists during the swap, so this
     CSS doesn't affect the steady state. We also speed up shared-element
     transitions a touch and ease them on the same curve. */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 520ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
  }
  ::view-transition-old(root) {
    animation-name: rt-out;
  }
  ::view-transition-new(root) {
    animation-name: rt-in;
  }
  @keyframes rt-out {
    0%   { opacity: 1; transform: translateY(0)    scale(1);    filter: blur(0); }
    100% { opacity: 0; transform: translateY(-2vh) scale(0.985); filter: blur(6px); }
  }
  @keyframes rt-in {
    0%   { opacity: 0; transform: translateY(2vh)  scale(0.99);  filter: blur(6px); }
    100% { opacity: 1; transform: translateY(0)    scale(1);     filter: blur(0); }
  }

  /* Shared elements (transition:name on <h1>, hero images, etc.):
     swap the default browser cross-fade for a faster expo-out so morphs
     feel snappy instead of dissolving. */
  ::view-transition-group(*) {
    animation-duration: 460ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 1ms;
      animation-name: none;
    }
  }

  /* ── Grain ──────────────────────────────────────────────────────────── */
  #grain {
    position: fixed;
    inset: -50%;
    width: 200%;
    height: 200%;
    z-index: 1000;
    pointer-events: none;
    opacity: 0.038;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    background-repeat: repeat;
    animation: grain-shift 0.5s steps(1) infinite;
    mix-blend-mode: overlay;
  }

  @keyframes grain-shift {
    0%   { transform: translate(0,    0);   }
    10%  { transform: translate(-3%,  -5%); }
    20%  { transform: translate(5%,   -2%); }
    30%  { transform: translate(-4%,   4%); }
    40%  { transform: translate(3%,    6%); }
    50%  { transform: translate(-6%,  -3%); }
    60%  { transform: translate(4%,    2%); }
    70%  { transform: translate(-2%,  -6%); }
    80%  { transform: translate(5%,    3%); }
    90%  { transform: translate(-3%,   5%); }
    100% { transform: translate(2%,   -4%); }
  }

  /* ── Vignette ───────────────────────────────────────────────────────── */
  #vignette {
    position: fixed;
    inset: 0;
    z-index: 999;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 40%,
      transparent 40%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  /* ── Custom cursor ──────────────────────────────────────────────────── */
  #cursor-dot,
  #cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    transition: opacity 0.3s ease;
  }

  #cursor-dot {
    width: 6px;
    height: 6px;
    background: #fff;
    margin: -3px 0 0 -3px;
    mix-blend-mode: difference;
  }

  #cursor-ring {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    margin: -18px 0 0 -18px;
    mix-blend-mode: difference;
    transition:
      width 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      height 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      margin 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.3s ease,
      background 0.2s ease;
  }

  #cursor-ring.is-hovering {
    width: 64px;
    height: 64px;
    margin: -32px 0 0 -32px;
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.9);
  }

  #cursor-ring.is-text {
    width: 3px;
    height: 28px;
    margin: -14px 0 0 -1.5px;
    border-radius: 2px;
    border-color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.15);
  }

  /* ── Reading mode (article pages) ────────────────────────────────────
     On article-like pages we replace the dot+ring with a single thin
     I-beam that's tuned for reading prose. Hovering links keeps the
     ring expansion so navigation still feels interactive. */
  body.is-reading #cursor-dot {
    opacity: 0;
  }
  body.is-reading #cursor-ring {
    width: 2px;
    height: 22px;
    margin: -11px 0 0 -1px;
    border-radius: 1px;
    border: none;
    background: rgba(255, 255, 255, 0.85);
    mix-blend-mode: difference;
  }
  body.is-reading #cursor-ring.is-text {
    /* Same I-beam shape — but a touch taller + a horizontal serif on
       top/bottom drawn via box-shadow, like a real text caret. */
    width: 2px;
    height: 24px;
    margin: -12px 0 0 -1px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow:
      -3px -11px 0 -1px rgba(255, 255, 255, 0.95),
       3px -11px 0 -1px rgba(255, 255, 255, 0.95),
      -3px  11px 0 -1px rgba(255, 255, 255, 0.95),
       3px  11px 0 -1px rgba(255, 255, 255, 0.95);
  }
  body.is-reading #cursor-ring.is-hovering {
    /* Tasteful smaller hover ring on links inside articles — doesn't
       overwhelm the prose like the 64px global hover state would. */
    width: 32px;
    height: 32px;
    margin: -16px 0 0 -16px;
    border: 1px solid rgba(255, 255, 255, 0.85);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    box-shadow: none;
  }

  /* Hide native cursor only when the custom-cursor JS has activated.
     Without this guard, a no-JS load (slow connection, content-blocker,
     prefers-reduced-motion early-return) would leave the user with no
     cursor at all. The class is added by the cursor IIFE in the inline
     script below — so the activation is conditional on the same checks
     (no coarse pointer, no reduced-motion). */
  html.cursor-custom {
    cursor: none;
  }

  /* Re-enable on touch devices (custom cursor is hidden anyway) */
  @media (hover: none), (pointer: coarse) {
    html, html.cursor-custom { cursor: auto; }
    #cursor-dot, #cursor-ring { display: none; }
    #grain { animation: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    #grain { animation: none; }
    /* Reduced-motion users keep the native cursor — the custom one
       skips activation, and the html.cursor-custom guard prevents
       cursor:none from sticking. */
    html, html.cursor-custom { cursor: auto; }
    #cursor-dot, #cursor-ring { display: none; }
  }

  /* Pause grain when tab hidden — saves GPU wakeups */
  html.is-hidden #grain { animation-play-state: paused; }
</style>

<script>
  // Skip entirely on touch/coarse-pointer devices and when the user prefers reduced motion.
  const isCoarse = matchMedia('(hover: none), (pointer: coarse)').matches;
  const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!isCoarse && !prefersReducedMotion) {
    const dot = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    if (!dot || !ring) throw new Error('Cursor elements not found');

    // Activate custom-cursor mode — only now is `cursor: none` applied.
    // Until this class is present, the native cursor stays visible, so
    // a JS error or slow hydration never strands the user without a
    // cursor.
    document.documentElement.classList.add('cursor-custom');

    let mouseX = -100, mouseY = -100;
    let ringX  = -100, ringY  = -100;
    let magnetTarget: Element | null = null;
    let rafId = 0;
    let running = false;
    let lastMoveAt = 0;

    const LERP = 0.12;
    const IDLE_MS = 2000; // stop RAF after this long without movement
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    function step() {
      const now = performance.now();

      if (magnetTarget) {
        const r = magnetTarget.getBoundingClientRect();
        const cx = r.left + r.width  / 2;
        const cy = r.top  + r.height / 2;
        ringX = lerp(ringX, mouseX + (cx - mouseX) * 0.18, LERP * 1.4);
        ringY = lerp(ringY, mouseY + (cy - mouseY) * 0.18, LERP * 1.4);
      } else {
        ringX = lerp(ringX, mouseX, LERP);
        ringY = lerp(ringY, mouseY, LERP);
      }
      dot!.style.transform  = `translate(${mouseX}px,${mouseY}px)`;
      ring!.style.transform = `translate(${ringX}px,${ringY}px)`;

      // Keep ticking while the ring hasn't settled or the user moved recently.
      const settled =
        Math.abs(ringX - mouseX) < 0.1 &&
        Math.abs(ringY - mouseY) < 0.1 &&
        now - lastMoveAt > IDLE_MS;
      if (settled) {
        running = false;
      } else {
        rafId = requestAnimationFrame(step);
      }
    }
    function start() {
      if (running || document.hidden) return;
      running = true;
      rafId = requestAnimationFrame(step);
    }

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      lastMoveAt = performance.now();
      start();
    }, { passive: true });

    document.addEventListener('mouseleave', () => {
      dot.style.opacity = '0';
      ring.style.opacity = '0';
    });
    document.addEventListener('mouseenter', () => {
      dot.style.opacity = '1';
      ring.style.opacity = '1';
      start();
    });

    function updateHoverFromTarget(t: Element | null) {
      if (!t) {
        ring!.classList.remove('is-hovering', 'is-text');
        magnetTarget = null;
        return;
      }
      const el = t.closest('a, button, [data-cursor-hover]');
      const tx = t.closest('p, h1, h2, h3, h4, h5, h6, li, blockquote, figcaption, span, label');
      if (el) {
        ring!.classList.add('is-hovering');
        ring!.classList.remove('is-text');
        magnetTarget = el;
      } else if (tx) {
        ring!.classList.add('is-text');
        ring!.classList.remove('is-hovering');
        magnetTarget = null;
      } else {
        ring!.classList.remove('is-hovering', 'is-text');
        magnetTarget = null;
      }
    }

    document.addEventListener('mouseover', (e) => {
      updateHoverFromTarget(e.target as Element);
    });

    // After an Astro view transition the body content has been swapped
    // but the user's mouse hasn't moved — no fresh `mouseover` event
    // fires, so the cursor state would carry over from the previous page
    // (e.g. stuck in `is-hovering` after clicking a link). Re-evaluate
    // what's under the cursor as soon as the new DOM is in place.
    document.addEventListener('astro:page-load', () => {
      const under = document.elementFromPoint(mouseX, mouseY);
      updateHoverFromTarget(under);
      // Force a tick of the RAF loop so the dot/ring snap to the right
      // place (the elements persisted, but their transforms are still
      // those left over from when the previous page unmounted).
      lastMoveAt = performance.now();
      start();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(rafId);
        running = false;
      } else {
        start();
      }
    });
  }

  // Pause grain when tab hidden — animation-play-state toggle via class.
  document.addEventListener('visibilitychange', () => {
    document.documentElement.classList.toggle('is-hidden', document.hidden);
  });
</script>
