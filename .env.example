# ─────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────

# ── Contact form ────────────────────────────────────────────────────
# Web3Forms access key.
#   1. Go to https://web3forms.com/#start
#   2. Enter max.richter.dev@proton.me → receive a free access key
#   3. Paste here. Every form submission is forwarded to that inbox.
#
# The PUBLIC_ prefix exposes the key to the client bundle — that's
# required because the form posts directly from the browser.
# Web3Forms access keys are designed to be public and scoped per-
# destination; they cannot be abused to send to another address.
PUBLIC_WEB3FORMS_KEY=

# ── Live stats fetcher (build-time only — never reaches the browser)
# Used by scripts/fetch-live-stats.mjs to refresh src/data/live-stats.json
# nightly via the GitHub Action under .github/workflows/. Missing vars
# don't break the build — the previous snapshot keeps shipping.

# Strava — register an app at https://www.strava.com/settings/api.
# Refresh token is obtained once via the OAuth code-grant flow and
# reused indefinitely (see scripts/fetch-live-stats.mjs).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# GitHub — fine-grained PAT with read access to repository metadata
# and the user's profile. Enables contributionsCollection (matches
# the green-heatmap total, includes private contributions when
# "Include private contributions in profile" is enabled at
# github.com/settings/profile). Without a token the GitHub fetch is
# skipped entirely and the previous snapshot stays.
GITHUB_TOKEN=
# Optional username override; defaults to "richter-max" inside the script.
GITHUB_USER=
